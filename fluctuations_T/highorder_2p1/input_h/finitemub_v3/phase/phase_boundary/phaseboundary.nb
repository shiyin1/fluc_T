       RowBox[{
        RowBox[{
         RowBox[{"Interpolation", "[", 
          RowBox[{"mf", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], "[", "x", "]"}], ",", "x"}],
        "]"}]}], ",", 
