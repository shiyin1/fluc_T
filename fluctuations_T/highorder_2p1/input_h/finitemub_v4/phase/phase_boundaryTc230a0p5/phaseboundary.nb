Cell[BoxData[{
 RowBox[{
  RowBox[{"mf", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Transpose", "[", 
       RowBox[{"Import", "[", 
        RowBox[{"\"\<./TemB\>\"", "<>", 
         RowBox[{"ToString", "[", "i", "]"}], 
         "<>", "\"\</BUFFER/MF.DAT\>\""}], "]"}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "37"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"intdmfdt", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Interpolation", "[", 
          RowBox[{"mf", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], "[", "x", "]"}], ",", "x"}],
        "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "37"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mub", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"{", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"i", "*", "15"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "37"}], "}"}]}], "]"}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Tpc", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"FindMaximum", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"intdmfdt", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{"90", "<", "x", "<", "200"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "160"}], "}"}]}], "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "37"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"peak", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"FindMaximum", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"intdmfdt", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ",", 
          RowBox[{"90", "<", "x", "<", "200"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "160"}], "}"}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "37"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Tpcup80", "=", 
