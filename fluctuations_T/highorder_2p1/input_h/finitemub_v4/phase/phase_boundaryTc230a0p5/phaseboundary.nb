    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"FindRoot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"intdmfdt", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "==", 
          RowBox[{
           RowBox[{"peak", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "*", "0.8"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{
            RowBox[{"Tpc", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "+", "5"}]}], "}"}]}], "]"}], "[", 
