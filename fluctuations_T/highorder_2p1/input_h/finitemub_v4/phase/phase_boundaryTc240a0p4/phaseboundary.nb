         "Black"}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<T\>\"", ",", "15", ",", "Black"}], "]"}]}], "}"}]}]}], 
  "]"}], "\[IndentingNewLine]", 
