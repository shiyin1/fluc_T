Cell[BoxData[{
 RowBox[{
  RowBox[{"Freezeoutplot", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Tfo", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "800"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Red"}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", "\"\<Freeze-out Andronic et al.\>\"", "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Right", ",", "Top"}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Phase", "=", 
