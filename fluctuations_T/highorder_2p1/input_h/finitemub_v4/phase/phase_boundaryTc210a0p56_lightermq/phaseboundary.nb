Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"mubfo", "[", "sqrts_", "]"}], ":=", 
   FractionBox["1307.5", 
    RowBox[{"1", "+", 
     RowBox[{"0.288", " ", "sqrts"}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sqrts", "[", "muB_", "]"}], ":=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"1.7361111111111112`", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2615.`"}], "+", 
        RowBox[{"2.`", " ", "muB"}]}], ")"}]}], "muB"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Tfo", "[", "muB_", "]"}], ":=", 
   FractionBox["158.4", 
    RowBox[{"1", "+", 
     RowBox[{"Exp", "[", 
      RowBox[{"2.60", "-", 
       FractionBox[
        RowBox[{"Log", "[", 
         FractionBox[
          RowBox[{
           FractionBox["1307.5", "muB"], "-", "1"}], "0.288"], "]"}], 
        "0.45"]}], "]"}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"STARFitI", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"Import", "[", "\"\<./freezeout/mub.dat\>\"", "]"}], "]"}], ",", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Import", "[", "\"\<./freezeout/STARFitI.dat\>\"", "]"}], 
       "]"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"STARFitII", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"Import", "[", "\"\<./freezeout/mub.dat\>\"", "]"}], "]"}], ",", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Import", "[", "\"\<./freezeout/STARFitII.dat\>\"", "]"}], 
       "]"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TI", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Interpolation", "[", "STARFitI", "]"}], "[", 
      RowBox[{"mub", "[", 
