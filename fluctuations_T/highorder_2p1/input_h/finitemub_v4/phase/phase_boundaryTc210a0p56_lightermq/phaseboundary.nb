     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "36"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"intdmfdt", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Interpolation", "[", 
          RowBox[{"mf", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], "[", "x", "]"}], ",", "x"}],
        "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "36"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mub", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"{", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"i", "*", "15"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "36"}], "}"}]}], "]"}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Tpc", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"FindMaximum", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"intdmfdt", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", 
            RowBox[{"90", "<", "x", "<", "170"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "150"}], "}"}]}], "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}], ",", 
